generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum MemoryEventType {
  quick_note
  task
  idea
  important
  reflection
  meeting
  manual
}

enum CaptureSource {
  dongle
  mobile_app
  airpods_shortcut
}

enum ButtonGesture {
  single_press
  double_press
  triple_press
  long_press
  press_and_hold
  hold_and_speak
}

enum RecordingStatus {
  created
  recording
  uploading
  uploaded
  processing
  completed
  failed
  deleted
}

enum AiJobStatus {
  pending
  processing
  completed
  failed
  retrying
  cancelled
}

enum AiJobType {
  transcription
  classification
  summary
  action_extraction
  reminder_suggestion
  embedding
  timeline_update
  insight
  cleanup
}

enum InsightType {
  recurring_theme
  unresolved_question
  similar_past_note
  project_direction
  emotional_pattern
  forgotten_task
  decision_needed
}

enum EntityType {
  person
  project
  vehicle
  pet
  health
  place
  device
  home
  idea
  organization
  other
}

enum EntityRelationType {
  related_to
  part_of
  belongs_to
  works_on
  owns
  uses
  discussed_with
  affects
  located_at
  other
}

enum AiSuggestionType {
  follow_up
  unresolved_task
  reminder_candidate
  repeated_topic
  decision_needed
  continue_project
  review_memory
}

enum AiSuggestionStatus {
  pending
  accepted
  dismissed
  done
}

enum AudioRetentionMode {
  delete_after_processing
  keep_7_days
  keep_30_days
  keep_forever
}

enum TranscriptRetentionMode {
  keep_forever
  delete_after_30_days
  delete_after_90_days
}

enum AiProcessingMode {
  cloud
  local_only
  hybrid
}

enum AudioDeletionStatus {
  deleted
  failed
  skipped
}

enum CaptureSessionStatus {
  active
  completed
  cancelled
}

enum DeviceStatus {
  paired
  disconnected
  syncing
  error
}

enum DeviceType {
  dongle
}

enum DongleRecordingSyncStatus {
  stored_on_device
  metadata_synced
  transfer_in_progress
  transferred_to_phone
  uploaded_to_backend
  confirmed_by_backend
  safe_to_delete_from_device
  sync_failed
}

model User {
  id               String            @id @default(uuid())
  supabaseUserId   String            @unique
  email            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  devices          Device[]
  recordings       Recording[]
  captureSessions  CaptureSession[]
  memoryEvents     MemoryEvent[]
  memoryThreads    MemoryThread[]
  insights         Insight[]
  contextSnapshots ContextSnapshot[]
  transcripts      Transcript[]
  notes            Note[]
  noteChunks       NoteChunk[]
  tags             Tag[]
  noteTags         NoteTag[]
  actionItems      ActionItem[]
  reminders        Reminder[]
  dailySummaries   DailySummary[]
  aiJobs           AiJob[]
  syncItems        SyncItem[]
  entities         Entity[]
  entityMentions   EntityMention[]
  entityRelations  EntityRelation[]
  aiSuggestions    AiSuggestion[]
  settings         UserSettings?
  audioDeletionLogs AudioDeletionLog[]

  @@index([supabaseUserId])
}

model UserSettings {
  id                      String                  @id @default(uuid())
  userId                  String                  @unique
  user                    User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  audioRetentionMode      AudioRetentionMode      @default(delete_after_processing)
  transcriptRetentionMode TranscriptRetentionMode @default(keep_forever)
  aiProcessingMode        AiProcessingMode        @default(cloud)
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  @@index([userId])
}

model Device {
  id                     String            @id @default(uuid())
  userId                 String
  user                   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  hardwareId             String
  type                   DeviceType        @default(dongle)
  displayName            String?
  firmwareVersion        String?
  batteryLevel           Int?
  storageCapacityBytes   Int?
  storageUsedBytes       Int?
  supportsOfflineCapture Boolean           @default(false)
  firmwareStorageVersion String?
  status                 DeviceStatus      @default(paired)
  pairedAt               DateTime          @default(now())
  lastSeenAt             DateTime?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  recordings             Recording[]
  captureSessions        CaptureSession[]
  memoryEvents           MemoryEvent[]
  contextSnapshots       ContextSnapshot[]

  @@unique([userId, hardwareId])
  @@index([userId])
}

model Recording {
  id                     String                     @id @default(uuid())
  userId                 String
  user                   User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId               String?
  device                 Device?                    @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  status                 RecordingStatus            @default(created)
  captureSource          CaptureSource
  storageBucket          String
  storagePath            String
  mimeType               String?
  durationMs             Int?
  sizeBytes              Int?
  uploadedAt             DateTime?
  deviceLocalRecordingId String?
  originalDeviceId       String?
  capturedOffline        Boolean                    @default(false)
  dongleSyncStatus       DongleRecordingSyncStatus?
  deviceCreatedAt        DateTime?
  deviceDurationMs       Int?
  deviceAudioCodec       String?
  deviceChecksum         String?
  audioDeletionScheduledAt DateTime?
  audioDeletedAt         DateTime?
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  memoryEvent            MemoryEvent?
  transcript             Transcript?
  captureSession         CaptureSession?
  aiJobs                 AiJob[]
  entityMentions         EntityMention[]
  syncItems              SyncItem[]
  audioDeletionLogs      AudioDeletionLog[]

  @@unique([deviceId, deviceLocalRecordingId])
  @@index([userId, status])
  @@index([deviceId])
  @@index([dongleSyncStatus])
  @@index([audioDeletionScheduledAt])
  @@index([createdAt])
}

model AudioDeletionLog {
  id          String              @id @default(uuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  recordingId String?
  recording   Recording?          @relation(fields: [recordingId], references: [id], onDelete: SetNull)
  storagePath String
  reason      String
  deletedAt   DateTime            @default(now())
  status      AudioDeletionStatus

  @@index([userId, deletedAt])
  @@index([recordingId])
  @@index([status])
}

model CaptureSession {
  id                String               @id @default(uuid())
  userId            String
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId          String?
  device            Device?              @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  recordingId       String?              @unique
  recording         Recording?           @relation(fields: [recordingId], references: [id], onDelete: SetNull)
  contextSnapshotId String?              @unique
  contextSnapshot   ContextSnapshot?     @relation(fields: [contextSnapshotId], references: [id], onDelete: SetNull)
  source            CaptureSource
  buttonGesture     ButtonGesture?
  status            CaptureSessionStatus @default(active)
  startedAt         DateTime             @default(now())
  completedAt       DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([userId, status])
  @@index([deviceId])
}

model MemoryEvent {
  id                String           @id @default(uuid())
  userId            String
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  recordingId       String?          @unique
  recording         Recording?       @relation(fields: [recordingId], references: [id], onDelete: SetNull)
  transcriptId      String?          @unique
  noteId            String?          @unique
  contextSnapshotId String?          @unique
  contextSnapshot   ContextSnapshot? @relation(fields: [contextSnapshotId], references: [id], onDelete: SetNull)
  memoryThreadId    String?
  memoryThread      MemoryThread?    @relation(fields: [memoryThreadId], references: [id], onDelete: SetNull)
  note              Note?
  deviceId          String?
  device            Device?          @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  type              MemoryEventType  @default(quick_note)
  captureSource     CaptureSource
  buttonGesture     ButtonGesture?
  occurredAt        DateTime
  title             String?
  summary           String?
  confidence        Float?
  importanceScore   Float            @default(0)
  emotionalScore    Float?
  semanticHash      String?
  processingStatus  String           @default("created")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  aiJobs            AiJob[]
  entityMentions    EntityMention[]
  aiSuggestions     AiSuggestion[]

  @@index([userId, occurredAt])
  @@index([userId, type])
  @@index([memoryThreadId])
  @@index([processingStatus])
  @@index([transcriptId])
  @@index([noteId])
  @@index([recordingId])
}

model MemoryThread {
  id                String        @id @default(uuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title             String
  description       String?
  firstSeenAt       DateTime
  lastSeenAt        DateTime
  notesCount        Int           @default(0)
  importanceScore   Float         @default(0)
  unresolvedCount   Int           @default(0)
  emotionalTrend    String?
  semanticClusterId String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  memoryEvents      MemoryEvent[]
  insights          Insight[]

  @@index([userId, lastSeenAt])
  @@index([userId, importanceScore])
  @@index([semanticClusterId])
}

model Insight {
  id              String        @id @default(uuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            InsightType
  title           String
  body            String
  relatedThreadId String?
  relatedThread   MemoryThread? @relation(fields: [relatedThreadId], references: [id], onDelete: SetNull)
  relatedNoteIds  String[]
  importanceScore Float         @default(0)
  isRead          Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId, isRead])
  @@index([userId, importanceScore])
  @@index([relatedThreadId])
}

model ContextSnapshot {
  id                  String          @id @default(uuid())
  userId              String
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  timestamp           DateTime
  timezone            String
  location            Json?
  calendarContext     Json?
  deviceState         Json?
  appState            Json?
  captureSource       CaptureSource
  buttonGesture       ButtonGesture?
  nearbyDeviceId      String?
  nearbyDevice        Device?         @relation(fields: [nearbyDeviceId], references: [id], onDelete: SetNull)
  userSelectedProject String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  memoryEvent         MemoryEvent?
  captureSession      CaptureSession?

  @@index([userId, timestamp])
  @@index([nearbyDeviceId])
}

model Transcript {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  recordingId String    @unique
  recording   Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  language    String?
  text        String
  segments    Json?
  provider    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  entityMentions EntityMention[]

  @@index([userId])
}

model Note {
  id            String       @id @default(uuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  memoryEventId String       @unique
  memoryEvent   MemoryEvent  @relation(fields: [memoryEventId], references: [id], onDelete: Cascade)
  title         String?
  summary       String?
  body          String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  chunks        NoteChunk[]
  noteTags      NoteTag[]
  actionItems   ActionItem[]
  reminders     Reminder[]
  entityMentions EntityMention[]
  aiSuggestions AiSuggestion[]

  @@index([userId, createdAt])
}

model Entity {
  id             String          @id @default(uuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  normalizedName String
  type           EntityType
  summary        String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  mentions       EntityMention[]
  outgoingRelations EntityRelation[] @relation("SourceEntityRelations")
  incomingRelations EntityRelation[] @relation("TargetEntityRelations")
  aiSuggestions AiSuggestion[]

  @@unique([userId, normalizedName])
  @@index([userId, name])
  @@index([userId, type])
  @@index([updatedAt])
}

model EntityRelation {
  id             String             @id @default(uuid())
  userId         String
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceEntityId String
  sourceEntity   Entity             @relation("SourceEntityRelations", fields: [sourceEntityId], references: [id], onDelete: Cascade)
  targetEntityId String
  targetEntity   Entity             @relation("TargetEntityRelations", fields: [targetEntityId], references: [id], onDelete: Cascade)
  relationType   EntityRelationType
  confidence     Float
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([userId, sourceEntityId, targetEntityId, relationType])
  @@index([userId])
  @@index([sourceEntityId])
  @@index([targetEntityId])
}

model AiSuggestion {
  id                   String             @id @default(uuid())
  userId               String
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  title                String
  body                 String
  type                 AiSuggestionType
  status               AiSuggestionStatus @default(pending)
  relatedEntityId      String?
  relatedEntity        Entity?            @relation(fields: [relatedEntityId], references: [id], onDelete: SetNull)
  relatedNoteId        String?
  relatedNote          Note?              @relation(fields: [relatedNoteId], references: [id], onDelete: SetNull)
  relatedMemoryEventId String?
  relatedMemoryEvent   MemoryEvent?       @relation(fields: [relatedMemoryEventId], references: [id], onDelete: SetNull)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([userId, status])
  @@index([userId, type])
  @@index([relatedEntityId])
  @@index([relatedNoteId])
  @@index([relatedMemoryEventId])
}

model EntityMention {
  id            String       @id @default(uuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityId      String
  entity        Entity       @relation(fields: [entityId], references: [id], onDelete: Cascade)
  noteId        String?
  note          Note?        @relation(fields: [noteId], references: [id], onDelete: Cascade)
  transcriptId  String?
  transcript    Transcript?  @relation(fields: [transcriptId], references: [id], onDelete: Cascade)
  memoryEventId String?
  memoryEvent   MemoryEvent? @relation(fields: [memoryEventId], references: [id], onDelete: Cascade)
  recordingId   String?
  recording     Recording?   @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  confidence    Float
  createdAt     DateTime     @default(now())

  @@index([userId])
  @@index([entityId, createdAt])
  @@index([noteId])
  @@index([transcriptId])
  @@index([memoryEventId])
  @@index([recordingId])
}

model NoteChunk {
  id        String                 @id @default(uuid())
  userId    String
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  noteId    String
  note      Note                   @relation(fields: [noteId], references: [id], onDelete: Cascade)
  content   String
  ordinal   Int
  embedding Unsupported("vector")?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  @@index([userId])
  @@index([noteId, ordinal])
}

model Tag {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  noteTags  NoteTag[]

  @@unique([userId, name])
  @@index([userId])
}

model NoteTag {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  noteId    String
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([noteId, tagId])
  @@index([userId])
  @@index([tagId])
}

model ActionItem {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  noteId      String
  note        Note      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueAt       DateTime?
  completedAt DateTime?
  source      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, completedAt])
  @@index([noteId])
}

model Reminder {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  noteId      String?
  note        Note?     @relation(fields: [noteId], references: [id], onDelete: SetNull)
  title       String
  remindAt    DateTime
  dismissedAt DateTime?
  source      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, remindAt])
  @@index([noteId])
}

model DailySummary {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  summary   String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId])
}

model AiJob {
  id            String       @id @default(uuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          AiJobType
  status        AiJobStatus  @default(pending)
  recordingId   String?
  recording     Recording?   @relation(fields: [recordingId], references: [id], onDelete: SetNull)
  memoryEventId String?
  memoryEvent   MemoryEvent? @relation(fields: [memoryEventId], references: [id], onDelete: SetNull)
  attempts      Int          @default(0)
  lastError     String?
  payload       Json?
  scheduledAt   DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([userId, status])
  @@index([type, status])
  @@index([recordingId])
  @@index([memoryEventId])
}

model SyncItem {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  recordingId String?
  recording   Recording? @relation(fields: [recordingId], references: [id], onDelete: SetNull)
  entityType  String
  entityId    String
  operation   String
  status      String
  payload     Json?
  syncedAt    DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId, status])
  @@index([entityType, entityId])
}
