DATABASE_URL=postgresql://postgres:postgres@localhost:5432/voxa
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
REDIS_URL=redis://localhost:6379
CORS_ORIGINS=http://localhost:19006,http://localhost:8081,http://localhost:3000
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
LLM_PROVIDER_ORDER=gemini,deepseek,openai,local
LLM_TIMEOUT_MS=30000
LLM_RETRY_ATTEMPTS=2

# DeepSeek / OpenAI-compatible provider (DeepSeek)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
STT_PROVIDER=whisper_http
STT_HTTP_ENDPOINT=http://127.0.0.1:8002/transcribe
TTS_PROVIDER=piper_http
TTS_HTTP_ENDPOINT=http://127.0.0.1:8003/synthesize
TTS_TIMEOUT_MS=60000
ENABLE_DONGLE_MODE=false
PORT=3000
